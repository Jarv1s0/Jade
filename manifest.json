{
    "manifest_version": 3,
    "default_locale": "zh_CN",
    "name": "__MSG_extName__",
    "version": "1.1",
    "description": "__MSG_extDescription__",
    "permissions": [
        "bookmarks",
        "tabs",
        "favicon",
        "sessions",
        "history",
        "sidePanel",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "https://bing.ee123.net/*",
        "https://www.bing.com/*",
        "https://global.bing.com/*",
        "https://api.nasa.gov/*",
        "https://picsum.photos/*",
        "https://translate.googleapis.com/*",
        "https://api.mymemory.translated.net/*"
    ],
    "action": {
        "default_popup": "bookmarks/popup.html"
    },
    "side_panel": {
        "default_path": "bookmarks/popup.html"
    },
    "chrome_url_overrides": {
        "newtab": "newtab/index.html"
    },
    "icons": {
        "128": "bookmarks/icon128.png"
    }
}
